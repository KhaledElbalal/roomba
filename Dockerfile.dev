# Development image for the Roomba Rails API.
FROM ruby:3.4.9-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      libpq-dev \
      git \
      curl \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

WORKDIR /rails

# Install gems first for layer caching.
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy the source (overridden by the compose bind-mount at runtime).
COPY . .

EXPOSE 3000

# Clear any stale PID (survives via the bind-mount across restarts), prepare the
# DB (idempotent), then bind the server to all interfaces on 3000.
CMD ["sh", "-c", "rm -f tmp/pids/server.pid && bin/rails db:prepare && bin/rails server -b 0.0.0.0 -p 3000"]
