# Development image for the Roomba Rails API.
FROM ruby:3.4.9-slim

RUN apt-get update -qq && \
    apt-get install --no-install-recommends -y \
      build-essential \
      libpq-dev \
      git \
      curl \
    && rm -rf /var/lib/apt/lists/* /var/cache/apt/archives/*

WORKDIR /rails

# Install gems first for layer caching.
COPY Gemfile Gemfile.lock ./
RUN bundle install

# Copy the source (overridden by the compose bind-mount at runtime).
COPY . .

EXPOSE 3000

# The `bundle` named volume persists across rebuilds and shadows the image's
# baked-in gems, so a changed Gemfile.lock (new/updated gem) would otherwise fail
# boot with "Could not find <gem> in locally installed gems". Reconcile the volume
# on startup. Then clear any stale PID (survives via the bind-mount across
# restarts), prepare the DB (idempotent), and bind the server to all interfaces.
CMD ["sh", "-c", "(bundle check || bundle install) && rm -f tmp/pids/server.pid && bin/rails db:prepare && bin/rails server -b 0.0.0.0 -p 3000"]
